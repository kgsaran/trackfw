{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "trackfw/adr",
  "title": "ADR Frontmatter",
  "description": "JSON Schema for trackfw Architecture Decision Record frontmatter",
  "type": "object",
  "required": ["status", "date"],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["Draft", "Proposed", "Accepted", "Deprecated", "Superseded"]
    },
    "date": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "author": { "type": "string" },
    "superseded_by": { "type": "string" }
  }
}
