{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "trackfw/req",
  "title": "REQ Frontmatter",
  "description": "JSON Schema for trackfw Requirement frontmatter",
  "type": "object",
  "required": ["status", "date"],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["Open", "Closed", "Blocked"]
    },
    "date": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "author": { "type": "string" },
    "adr": { "type": "string" },
    "roadmap": { "type": "string" }
  }
}
